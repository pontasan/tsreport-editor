{
  "name": "tsreport-editor",
  "version": "1.0.0",
  "description": "Browser-based report designer and report server built on tsreport-core: template editing with print-identical preview, workspace and font management, OAuth 2.0 print API with an async job queue, PDF import, and an MCP server for AI agents",
  "private": true,
  "packageManager": "npm@11.18.0",
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.18.0",
      "onFail": "error"
    }
  },
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/pontasan/tsreport-editor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pontasan/tsreport-editor.git"
  },
  "bugs": {
    "url": "https://github.com/pontasan/tsreport-editor/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "argon2": "0.43.1",
    "big.js": "^7.0.1",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.13",
    "negotiator": "^1.0.0",
    "next": "16.2.10",
    "pg": "^8.15.5",
    "pg-pool": "^3.9.5",
    "pg-types": "^4.0.2",
    "primeicons": "^7.0.0",
    "primereact": "9.6.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.34.5",
    "sql-template-strings": "^2.2.2",
    "tsreport-core": "1.0.0",
    "tsreport-react": "1.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/big.js": "^6.2.2",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20",
    "@types/pg": "^8.11.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.10"
  },
  "allowScripts": {
    "argon2@0.43.1": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true
  }
}
